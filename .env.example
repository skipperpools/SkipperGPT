# Skipper Pools Job Card Dashboard - environment config
# Copy this file to .env and adjust as needed.

# local | production
APP_ENV=local

# SQLite — local development only (via launch.bat / start-backend.ps1).
# Production no longer runs on SQLite/office PC; see deploy/README.md.
DATABASE_URL=sqlite:///./data/skipper.db

# Production (DigitalOcean droplet + DigitalOcean Managed PostgreSQL, NYC1):
# use the VPC connection string from the DO database cluster's Connection
# Details panel (private network, lower latency, not publicly exposed):
# DATABASE_URL=postgresql+psycopg://doadmin:PASSWORD@<vpc-host>:25060/defaultdb?sslmode=require

# Optional: full path to Schedules.xlsx (default: <project root>/Schedules.xlsx)
# SCHEDULE_XLSX_PATH=D:\SkipperGPT\Schedules.xlsx

# Where PDFs, photos, and sketches are stored (default: project root).
# Production droplet with block volume: DOCS_ROOT=/var/skipper
# DOCS_ROOT=D:\SkipperGPT

# Optional: max upload size per file in MB (default 25)
# MAX_UPLOAD_MB=25

# Web Push (optional — required for task push notifications)
# Generate with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_CONTACT_EMAIL=mailto:admin@skipperpools.net

# JWT auth (HS256). Use a long random value in production.
# SECRET_KEY=
# Optional: override token lifetime in minutes (default ~180 days). Example for dev: 60
# ACCESS_TOKEN_EXPIRE_MINUTES=60

# Comma-separated list of origins allowed for cross-origin API access.
# Leave empty if the FastAPI process also serves the UI (the default deploy).
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# Production example (copy to droplet /home/skipper/app/.env):
# APP_ENV=production
# DATABASE_URL=postgresql+psycopg://...
# DOCS_ROOT=/var/skipper
# SECRET_KEY=<python -c "import secrets; print(secrets.token_hex(32))">
# ACCESS_TOKEN_EXPIRE_MINUTES=10080
# CORS_ALLOWED_ORIGINS=
