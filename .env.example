# Skipper Pools Job Card Dashboard - environment config
# Copy this file to .env and adjust as needed.

# local | production
APP_ENV=local

# SQLite (default, for local office PC)
DATABASE_URL=sqlite:///./data/skipper.db

# Optional: full path to Schedules.xlsx (default: <project root>/Schedules.xlsx)
# SCHEDULE_XLSX_PATH=D:\SkipperGPT\Schedules.xlsx

# Optional: where PDFs and photos are stored (default: project root). Under this path,
# the app uses Docs/<job-folder>/ and Photos/<job-folder>/.
# DOCS_ROOT=D:\SkipperGPT

# Optional: max upload size per file in MB (default 25)
# MAX_UPLOAD_MB=25

# JWT auth (HS256). Use a long random value in production.
# SECRET_KEY=
# Optional: override token lifetime in minutes (default ~180 days). Example for dev: 60
# ACCESS_TOKEN_EXPIRE_MINUTES=60

# Comma-separated list of origins allowed for cross-origin API access.
# Leave empty if the FastAPI process also serves the UI (the default deploy).
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# -----------------------------------------------------------------------------
# Production (Render) values - render.yaml configures these automatically; this
# block is here for reference if you ever need to set them by hand.
# -----------------------------------------------------------------------------
# APP_ENV=production
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/skipper
# DOCS_ROOT=/var/skipper
# SECRET_KEY=<long-random-string>
# ACCESS_TOKEN_EXPIRE_MINUTES=10080
